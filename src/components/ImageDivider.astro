---
interface Props {
  alt?: string;
}

const { alt = "Austin, Texas" } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<div class="image-divider">
  <img src={`${baseUrl}austin-skyline-hero.jpg`} alt={alt} />
  <div class="divider-overlay"></div>
</div>

<style>
  .image-divider {
    position: relative;
    height: 300px;
    overflow: hidden;
  }

  .image-divider img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 70%;
  }

  .divider-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(26, 26, 46, 0.3) 0%,
      rgba(26, 26, 46, 0.5) 100%
    );
  }

  @media (max-width: 768px) {
    .image-divider {
      height: 200px;
    }
  }
</style>
