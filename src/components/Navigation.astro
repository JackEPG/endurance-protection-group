---
const navItems = [
  { label: 'Home', href: '#home' },
  { label: 'About', href: '#about' },
  { label: 'Team', href: '#team' },
  { label: 'Contact', href: '#contact' },
];
---

<header class="nav-header" id="nav">
  <nav class="nav-container">
    <a href="#home" class="nav-logo">
      <span class="logo-mark">EPG</span>
      <span class="logo-text">Endurance Protection Group</span>
    </a>

    <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
      <span class="hamburger"></span>
    </button>

    <ul class="nav-links">
      {navItems.map((item, i) => (
        <li style={`--delay: ${i * 0.05}s`}>
          <a href={item.href} class="nav-link">{item.label}</a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  .nav-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    transition: all 0.4s var(--ease-out-expo);
  }

  .nav-header::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(12, 18, 32, 0.9) 0%, rgba(12, 18, 32, 0) 100%);
    opacity: 1;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }

  .nav-header.scrolled::before {
    opacity: 0;
  }

  .nav-header.scrolled {
    background: rgba(250, 248, 245, 0.95);
    backdrop-filter: blur(20px);
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.05);
  }

  .nav-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 1.5rem 3rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: white;
    transition: color 0.4s ease;
  }

  .scrolled .nav-logo {
    color: var(--slate-900);
  }

  .logo-mark {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    padding: 0.4rem 0.6rem;
    border: 1.5px solid currentColor;
    line-height: 1;
  }

  .logo-text {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  @media (max-width: 900px) {
    .logo-text {
      display: none;
    }
  }

  .nav-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.75rem;
    margin-right: -0.75rem;
    position: relative;
    z-index: 1001;
  }

  .hamburger {
    display: block;
    width: 22px;
    height: 2px;
    background: white;
    position: relative;
    transition: background 0.3s ease;
  }

  .scrolled .hamburger,
  .scrolled .hamburger::before,
  .scrolled .hamburger::after {
    background: var(--slate-900);
  }

  .hamburger::before,
  .hamburger::after {
    content: '';
    position: absolute;
    width: 22px;
    height: 2px;
    background: white;
    left: 0;
    transition: transform 0.3s var(--ease-out-expo), top 0.3s var(--ease-out-expo);
  }

  .hamburger::before { top: -7px; }
  .hamburger::after { top: 7px; }

  .nav-toggle[aria-expanded="true"] .hamburger {
    background: transparent;
  }

  .nav-toggle[aria-expanded="true"] .hamburger::before {
    top: 0;
    transform: rotate(45deg);
    background: var(--slate-900);
  }

  .nav-toggle[aria-expanded="true"] .hamburger::after {
    top: 0;
    transform: rotate(-45deg);
    background: var(--slate-900);
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 3rem;
  }

  .nav-link {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.9);
    transition: color 0.3s ease;
    position: relative;
    padding: 0.25rem 0;
  }

  .scrolled .nav-link {
    color: var(--slate-600);
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: var(--copper-400);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.4s var(--ease-out-expo);
  }

  .nav-link:hover {
    color: white;
  }

  .scrolled .nav-link:hover {
    color: var(--slate-900);
  }

  .nav-link:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  @media (max-width: 768px) {
    .nav-container {
      padding: 1.25rem 1.5rem;
    }

    .nav-toggle {
      display: block;
    }

    .nav-links {
      position: fixed;
      top: 0;
      right: 0;
      bottom: 0;
      width: min(320px, 85vw);
      flex-direction: column;
      background: var(--cream);
      padding: 6rem 2.5rem 3rem;
      gap: 0;
      transform: translateX(100%);
      transition: transform 0.5s var(--ease-out-expo);
      box-shadow: -20px 0 60px rgba(0, 0, 0, 0.15);
    }

    .nav-links.active {
      transform: translateX(0);
    }

    .nav-links li {
      opacity: 0;
      transform: translateX(20px);
      transition: all 0.4s var(--ease-out-expo);
      transition-delay: var(--delay);
    }

    .nav-links.active li {
      opacity: 1;
      transform: translateX(0);
    }

    .nav-link {
      display: block;
      font-size: 1rem;
      color: var(--slate-700);
      padding: 1rem 0;
      border-bottom: 1px solid var(--slate-200);
    }

    .nav-link:hover {
      color: var(--slate-900);
    }
  }
</style>

<script>
  const nav = document.getElementById('nav');
  const toggle = document.querySelector('.nav-toggle');
  const navLinks = document.querySelector('.nav-links');
  const links = document.querySelectorAll('.nav-link');

  // Scroll behavior
  let lastScroll = 0;
  window.addEventListener('scroll', () => {
    const currentScroll = window.scrollY;

    if (currentScroll > 100) {
      nav?.classList.add('scrolled');
    } else {
      nav?.classList.remove('scrolled');
    }

    lastScroll = currentScroll;
  });

  // Mobile menu
  toggle?.addEventListener('click', () => {
    const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', (!isExpanded).toString());
    navLinks?.classList.toggle('active');
    document.body.style.overflow = isExpanded ? '' : 'hidden';
  });

  links.forEach(link => {
    link.addEventListener('click', () => {
      navLinks?.classList.remove('active');
      toggle?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    });
  });
</script>
