---
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

const team = [
  {
    name: "Jack T.",
    role: "Co-Founder",
    photo: "Trent_Jack_223-0434-Retouched.jpg",
    bio: "Jack is one of the co-founders of EPG, combining his years of experience serving leading insurers at McKinsey with his prior experience founding and running a small services business. He knows the challenges first hand of operating a small business and being successful in the insurance industry.",
    bio2: "A native Texan, Jack cares deeply about the social good that insurance provides to local Texas communities."
  }
];
---

<section id="team" class="team">
  <div class="container">
    <h2 class="team-main-title">Our Team</h2>

    <p class="team-description">
      The EPG founding team has decades worth of insurance and business operations experience, having served some of the largest carriers and distributors in the world as consultants. Similarly, EPG is advised by former operators and insurance industry leaders.
    </p>

    <h3 class="team-subtitle">Meet one of our co-founders</h3>

    <div class="team-grid">
      {team.map((member, index) => (
        <div class="team-column">
          <article class="team-card">
            <div class="team-photo">
              {member.photo ? (
                <img src={`${baseUrl}${member.photo}`} alt={member.name} />
              ) : (
                <div class="photo-placeholder">
                  <!-- Cartoon-style person placeholder SVG -->
                  <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg" class="placeholder-avatar">
                    <circle cx="60" cy="40" r="24" fill="#64748b"/>
                    <ellipse cx="60" cy="95" rx="35" ry="25" fill="#64748b"/>
                    <circle cx="52" cy="36" r="3" fill="#1e2d42"/>
                    <circle cx="68" cy="36" r="3" fill="#1e2d42"/>
                    <path d="M54 48 Q60 54 66 48" stroke="#1e2d42" stroke-width="2" stroke-linecap="round" fill="none"/>
                  </svg>
                </div>
              )}
            </div>
            <div class="team-info">
              <h3 class="team-name">{member.name}</h3>
              <p class="team-role">{member.role}</p>
            </div>
          </article>
          <p class="team-bio">{member.bio}</p>
          {member.bio2 && <p class="team-bio">{member.bio2}</p>}
        </div>
      ))}
    </div>
  </div>
  <!-- Divider line -->
  <div class="section-divider"></div>
</section>

<style>
  .team {
    background: var(--cream);
    padding: 4rem 2rem;
    position: relative;
    overflow: hidden;
  }

  .team-main-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    color: var(--slate-900);
    letter-spacing: -0.02em;
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .team-description {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--slate-700);
    text-align: center;
    max-width: 600px;
    margin: 0 auto 2.5rem;
  }

  .team-subtitle {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--slate-900);
    text-align: center;
    margin-bottom: 1.5rem;
    text-decoration: underline;
    text-decoration-color: var(--copper-400);
    text-underline-offset: 6px;
    text-decoration-thickness: 2px;
  }

  .team-grid {
    display: grid;
    grid-template-columns: 280px;
    gap: 3rem;
    justify-content: center;
    align-items: stretch;
  }

  .team-column {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .team-card {
    width: 100%;
    height: 320px;
    background: var(--cream);
    border: 3px solid #9ca3af;
    overflow: hidden;
    transition: all 0.4s var(--ease-out-expo);
    display: flex;
    flex-direction: column;
  }

  .team-card:hover {
    border-color: #d1d5db;
    box-shadow: 0 20px 40px -20px rgba(0, 0, 0, 0.4);
  }

  .team-photo {
    height: 240px;
    overflow: hidden;
    background: var(--slate-700);
    flex-shrink: 0;
  }

  .team-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transition: transform 0.6s var(--ease-out-expo);
  }

  .team-card:hover .team-photo img {
    transform: scale(1.03);
  }

  .team-info {
    padding: 1rem;
    text-align: center;
    background: var(--cream);
    height: 80px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    flex-shrink: 0;
  }

  .team-name {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--slate-900);
    margin-bottom: 0.25rem;
  }

  .team-role {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--copper-400);
  }

  .team-bio {
    width: 100%;
    margin-top: 1rem;
    font-size: 0.875rem;
    color: var(--slate-600);
    line-height: 1.7;
    text-align: center;
  }

  .team-bio:first-of-type {
    margin-top: 1.5rem;
  }

  .section-divider {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 80%;
    max-width: 600px;
    height: 1px;
    background: #d1d5db;
  }

  @media (max-width: 768px) {
    .team {
      padding: 3rem 1.5rem;
    }
  }
</style>
