---
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

const team = [
  {
    name: "Jack Trent",
    role: "Founder",
    photo: "Trent_Jack_223-0434-Retouched.jpg",
    bio: "Jack founded Endurance Protection Group with a vision to preserve the legacy of independent P&C insurance agencies across Texas."
  }
];
---

<section id="team" class="team">
  <div class="container">
    <h2 class="section-title">Our Team</h2>
    <p class="section-subtitle">
      Experienced operators committed to building lasting value
    </p>

    <div class="team-grid">
      {team.map((member) => (
        <div class="team-card">
          <div class="team-photo">
            {member.photo ? (
              <img src={`${baseUrl}${member.photo}`} alt={member.name} />
            ) : (
              <div class="photo-placeholder"></div>
            )}
          </div>
          <div class="team-info">
            <h3 class="team-name">{member.name}</h3>
            <p class="team-role">{member.role}</p>
            <p class="team-bio">{member.bio}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .team {
    background: #f8f9fa;
  }

  .section-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    text-align: center;
    margin-bottom: 1rem;
    color: #1a1a2e;
  }

  .section-subtitle {
    text-align: center;
    color: #5a5a6e;
    font-size: 1.125rem;
    margin-bottom: 3rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2.5rem;
    max-width: 450px;
    margin: 0 auto;
  }

  .team-card {
    background: white;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid #e5e5e5;
    transition: box-shadow 0.2s ease;
  }

  .team-card:hover {
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
  }

  .team-photo {
    aspect-ratio: 1;
    background: #e5e5e5;
    overflow: hidden;
  }

  .team-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .photo-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #e5e5e5 0%, #d0d0d0 100%);
  }

  .team-info {
    padding: 1.5rem;
  }

  .team-name {
    font-size: 1.25rem;
    color: #1a1a2e;
    margin-bottom: 0.25rem;
  }

  .team-role {
    font-size: 0.9375rem;
    color: #8a8a9a;
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .team-bio {
    font-size: 0.9375rem;
    color: #5a5a6e;
    line-height: 1.6;
  }
</style>
