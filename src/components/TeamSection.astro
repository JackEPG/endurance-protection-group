---
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

const team = [
  {
    name: "Jack T.",
    role: "Co-Founder",
    photo: "Trent_Jack_223-0434-Retouched.jpg",
    bio: "Jack is one of the co-founders of EPG, combining his years of experience serving leading insurers at McKinsey with his prior experience founding and running a small services business. He knows the challenges first hand of operating a small business and being successful in the insurance industry.",
    bio2: "A native Texan, Jack cares deeply about the social good that insurance provides to local Texas communities."
  },
  {
    name: "Other EPG Members",
    role: "Co-Founders & Advisors",
    photo: null,
    bio: "EPG's other co-founders bring decades of insurance and business operations experience. Similarly, EPG is advised by former operators, investors, and leaders in the insurance industry."
  }
];
---

<section id="team" class="team">
  <div class="team-title-wrapper">
    <h2 class="team-main-title">Our Team</h2>
  </div>
  <div class="container">

    <div class="team-grid">
      {team.map((member, index) => (
        <div class="team-column">
          <article class="team-card">
            <div class="team-photo">
              {member.photo ? (
                <img src={`${baseUrl}${member.photo}`} alt={member.name} />
              ) : (
                <div class="photo-placeholder">
                  <!-- Cartoon-style person placeholder SVG -->
                  <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg" class="placeholder-avatar">
                    <circle cx="60" cy="40" r="24" fill="#64748b"/>
                    <ellipse cx="60" cy="95" rx="35" ry="25" fill="#64748b"/>
                    <circle cx="52" cy="36" r="3" fill="#1e2d42"/>
                    <circle cx="68" cy="36" r="3" fill="#1e2d42"/>
                    <path d="M54 48 Q60 54 66 48" stroke="#1e2d42" stroke-width="2" stroke-linecap="round" fill="none"/>
                  </svg>
                </div>
              )}
            </div>
            <div class="team-info">
              <h3 class="team-name">{member.name}</h3>
              <p class="team-role">{member.role}</p>
            </div>
          </article>
          <p class="team-bio">{member.bio}</p>
          {member.bio2 && <p class="team-bio">{member.bio2}</p>}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .team {
    background: var(--slate-900);
    padding: 0 2rem 4rem;
    position: relative;
    overflow: hidden;
  }

  .team::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 20% 50%, rgba(184, 115, 51, 0.03) 0%, transparent 50%),
      radial-gradient(circle at 80% 80%, rgba(184, 115, 51, 0.02) 0%, transparent 40%);
    pointer-events: none;
  }

  .team-title-wrapper {
    background: var(--cream);
    padding: 2.5rem 2rem;
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .team-main-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    color: var(--slate-900);
    letter-spacing: -0.02em;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(2, 280px);
    gap: 3rem;
    justify-content: center;
    align-items: stretch;
  }

  @media (max-width: 620px) {
    .team-grid {
      grid-template-columns: 280px;
    }
  }

  .team-column {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .team-card {
    width: 100%;
    height: 320px;
    background: var(--slate-800);
    border: 3px solid #9ca3af;
    overflow: hidden;
    transition: all 0.4s var(--ease-out-expo);
    display: flex;
    flex-direction: column;
  }

  .team-card:hover {
    border-color: #d1d5db;
    box-shadow: 0 20px 40px -20px rgba(0, 0, 0, 0.4);
  }

  .team-photo {
    height: 240px;
    overflow: hidden;
    background: var(--slate-700);
    flex-shrink: 0;
  }

  .team-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transition: transform 0.6s var(--ease-out-expo);
  }

  .team-card:hover .team-photo img {
    transform: scale(1.03);
  }

  .photo-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--slate-700) 0%, var(--slate-600) 100%);
    padding: 2rem;
  }

  .placeholder-avatar {
    width: 80%;
    height: 80%;
    opacity: 0.8;
  }

  .team-info {
    padding: 1rem;
    text-align: center;
    background: var(--slate-800);
    height: 80px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    flex-shrink: 0;
  }

  .team-name {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 400;
    color: var(--slate-900);
    margin-bottom: 0.25rem;
  }

  .team-role {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--copper-400);
  }

  .team-bio {
    width: 100%;
    margin-top: 1rem;
    font-size: 0.875rem;
    color: var(--slate-400);
    line-height: 1.7;
    text-align: center;
  }

  .team-bio:first-of-type {
    margin-top: 1.5rem;
  }

  @media (max-width: 768px) {
    .team {
      padding: 0 1.5rem 3rem;
    }
  }
</style>
