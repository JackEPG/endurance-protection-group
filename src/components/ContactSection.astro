---
---

<section id="contact" class="contact">
  <div class="container">
    <h2 class="section-title">Contact Us</h2>
    <p class="section-subtitle">
      Interested in discussing a potential partnership? We'd love to hear from you.
    </p>

    <div class="contact-content">
      <div class="contact-info">
        <div class="contact-item">
          <h3>Email</h3>
          <a href="mailto:Info@EnduranceProtectionGroup.com">Info@EnduranceProtectionGroup.com</a>
        </div>

        <div class="contact-item">
          <h3>Location</h3>
          <p>Austin, Texas</p>
        </div>

        <div class="contact-message">
          <p>
            Whether you're an agency owner considering your succession options or someone who shares our passion for preserving independent insurance agencies—we welcome the conversation.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<footer class="footer">
  <div class="container">
    <p>&copy; {new Date().getFullYear()} Endurance Protection Group. All rights reserved.</p>
  </div>
</footer>

<style>
  .contact {
    background: #ffffff;
  }

  .section-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    text-align: center;
    margin-bottom: 1rem;
    color: #1a1a2e;
  }

  .section-subtitle {
    text-align: center;
    color: #5a5a6e;
    font-size: 1.125rem;
    margin-bottom: 3rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  .contact-content {
    max-width: 600px;
    margin: 0 auto;
  }

  .contact-info {
    text-align: center;
  }

  .contact-item {
    margin-bottom: 2rem;
  }

  .contact-item h3 {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #8a8a9a;
    margin-bottom: 0.5rem;
  }

  .contact-item a,
  .contact-item p {
    font-size: 1.25rem;
    color: #1a1a2e;
  }

  .contact-item a {
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: color 0.2s ease;
  }

  .contact-item a:hover {
    color: #5a5a6e;
  }

  .contact-message {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid #e5e5e5;
  }

  .contact-message p {
    color: #5a5a6e;
    font-size: 1rem;
    line-height: 1.7;
  }

  .footer {
    background: #1a1a2e;
    color: #8a8a9a;
    padding: 2rem 1.5rem;
    text-align: center;
  }

  .footer p {
    font-size: 0.875rem;
  }
</style>
