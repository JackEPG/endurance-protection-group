---
---

<section id="contact" class="contact">
  <div class="container">
    <header class="section-header">
      <h2 class="section-title">Let's Connect</h2>
    </header>

    <div class="contact-content">
      <p class="contact-description">
        Whether you're an agency owner considering your succession options or someone who shares our passion for preserving independent insurance agencies—we welcome the conversation.
      </p>

      <div class="contact-details">
        <a href="mailto:Info@EnduranceProtectionGroup.com" class="contact-card contact-email">
          <span class="contact-label">Email</span>
          <span class="contact-value">Info@EnduranceProtectionGroup.com</span>
        </a>

        <div class="contact-card">
          <span class="contact-label">Location</span>
          <span class="contact-value">Austin, Texas</span>
        </div>
      </div>
    </div>
  </div>
</section>

<footer class="footer">
  <div class="container">
    <div class="footer-content">
      <div class="footer-brand">
        <span class="footer-logo">EPG</span>
        <span class="footer-name">Endurance Protection Group</span>
      </div>

      <p class="footer-copyright">
        &copy; {new Date().getFullYear()} Endurance Protection Group. All rights reserved.
      </p>
    </div>
  </div>
</footer>

<style>
  .contact {
    background: var(--cream);
    padding: 4rem 2rem;
    position: relative;
  }

  .section-header {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    color: var(--slate-900);
    letter-spacing: -0.02em;
  }

  .contact-content {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  .contact-description {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--slate-700);
    margin-bottom: 2rem;
  }

  .contact-details {
    display: flex;
    flex-direction: row;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .contact-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem 2.5rem;
    background: #e8e8e8;
    border: none;
    text-align: center;
    transition: all 0.4s var(--ease-out-expo);
  }

  .contact-email {
    cursor: pointer;
  }

  .contact-email:hover {
    background: #d8d8d8;
  }

  .contact-label {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--slate-500);
  }

  .contact-value {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    color: var(--slate-900);
  }

  .contact-email .contact-value {
    text-decoration: underline;
    text-decoration-color: var(--copper-300);
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
  }

  /* Footer */
  .footer {
    background: var(--slate-950);
    padding: 3rem 2rem;
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .footer-logo {
    font-family: var(--font-serif);
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: white;
    padding: 0.3rem 0.5rem;
    border: 1px solid var(--slate-700);
  }

  .footer-name {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--slate-500);
  }

  .footer-copyright {
    font-size: 0.8125rem;
    color: var(--slate-600);
  }

  @media (max-width: 600px) {
    .footer-content {
      flex-direction: column;
      text-align: center;
    }

    .contact {
      padding: 3rem 1.5rem;
    }

    .footer {
      padding: 2.5rem 1.5rem;
    }

    .footer-name {
      display: none;
    }

    .contact-card {
      min-width: 100%;
    }
  }
</style>
