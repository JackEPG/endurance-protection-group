---
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<section id="home" class="hero">
  <div class="hero-background">
    <img src={`${baseUrl}austin-skyline-hero.jpg`} alt="Austin, Texas skyline" />
  </div>

  <!-- Sophisticated gradient overlay -->
  <div class="hero-overlay"></div>


  <div class="hero-content">
    <h1 class="hero-title reveal">
      Securing the Legacy of<br />
      <span class="title-accent">Independent Insurance Agencies</span>
    </h1>
    <p class="hero-subtitle reveal reveal-delay-1">
      Long-term stewards acquiring and operating property & casualty insurance agencies across Texas
    </p>
    <div class="hero-cta-wrapper reveal reveal-delay-2">
      <a href="#contact" class="hero-cta">
        <span>Start a Conversation</span>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>

</section>

<style>
  .hero {
    min-height: 85vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 6rem 2rem 3rem;
    position: relative;
    overflow: hidden;
  }

  .hero-background {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-background img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    transform: scale(1.05);
    animation: slowZoom 20s ease-out forwards;
  }

  @keyframes slowZoom {
    to {
      transform: scale(1);
    }
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg,
        rgba(12, 18, 32, 0.7) 0%,
        rgba(12, 18, 32, 0.5) 40%,
        rgba(12, 18, 32, 0.8) 100%
      );
    z-index: 1;
  }

  .hero-content {
    max-width: 900px;
    position: relative;
    z-index: 3;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 400;
    color: white;
    margin-bottom: 1.75rem;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .title-accent {
    font-style: italic;
    color: white;
  }

  .hero-subtitle {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.5vw, 1.125rem);
    color: white;
    margin-bottom: 3rem;
    max-width: 540px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.7;
  }

  .hero-cta-wrapper {
    display: inline-block;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    background: transparent;
    color: white;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.875rem;
    letter-spacing: 0.04em;
    border: 1px solid rgba(255, 255, 255, 0.3);
    transition: all 0.4s var(--ease-out-expo);
    position: relative;
    overflow: hidden;
  }

  .hero-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: white;
    transform: translateY(100%);
    transition: transform 0.4s var(--ease-out-expo);
    z-index: -1;
  }

  .hero-cta:hover {
    color: var(--slate-900);
    border-color: white;
  }

  .hero-cta:hover::before {
    transform: translateY(0);
  }

  .hero-cta svg {
    transition: transform 0.4s var(--ease-out-expo);
  }

  .hero-cta:hover svg {
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .hero {
      padding: 7rem 1.5rem 4rem;
    }

    .hero-title br {
      display: none;
    }

  }
</style>
